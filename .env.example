# LLM (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
# Backup models, tried in order if the primary model errors (rate limit, outage, etc.)
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b,llama-3.3-70b-versatile,llama-3.1-8b-instant

# Database
DATABASE_URL=sqlite:///./data/agentcare.db

# LangGraph workflow-state checkpointer: "memory" (dev, lost on restart) or "sqlite" (persistent)
LANGGRAPH_CHECKPOINTER=sqlite
LANGGRAPH_CHECKPOINT_DB=./data/checkpoints.db

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# File storage
UPLOAD_DIR=./uploads

# App
APP_ENV=development
